{
  "name": "pi-questionnaire",
  "version": "0.1.0",
  "description": "Rich, flexible questionnaire tool for pi coding agent. Supports single/multi-select with rich previews, text, confirm, and number question types — inspired by pag-server's questionnaire v2 contract.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "node --test --import tsx tests/*.test.ts",
    "test:py": "python3 -m pytest tests/ -v",
    "test:e2e": "bash tests/test_e2e_pi.sh",
    "test:all": "npm run test:py && bash tests/test_e2e_pi.sh"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "license": "MIT"
}
